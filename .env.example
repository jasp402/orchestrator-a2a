# Database
DATABASE_URL='postgresql://user:password@host/db?sslmode=require'

# Session signing
APP_SESSION_SECRET='replace-with-long-random-secret'

# Optional OTP delivery via Resend
RESEND_API_KEY='re_xxx'
RESEND_FROM_EMAIL='AITENETIA <auth@yourdomain.com>'
OTP_TTL_MINUTES='10'

# Optional shared secret for runtime license validation webhook
LICENSE_WEBHOOK_SECRET='replace-with-shared-secret'
